{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "allowJs": true,
    "checkJs": false,
    "strict": false,
    "noEmit": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "esModuleInterop": true
  },
  "include": [
    "scripts/**/*.mjs",
    "scripts/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "plugins/*/node_modules",
    "dist"
  ]
}

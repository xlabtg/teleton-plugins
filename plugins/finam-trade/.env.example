# Required: permanent Finam API secret from the Finam Trade API Tokens page.
FINAM_SECRET=your_secret_key_here

# Optional overrides for Teleton plugin config.
FINAM_API_BASE=https://api.finam.ru
FINAM_GRPC_BASE=api.finam.ru:443
FINAM_ENABLE_GRPC_JWT_RENEWAL=false
FINAM_RATE_LIMIT_RPS=3
FINAM_TIMEOUT_MS=30000
FINAM_CACHE_TTL=3600

# Optional live smoke-test inputs for:
#   npm run finam:live-smoke
# Use only a non-production account or the safest broker-provided test environment.
FINAM_LIVE_ACCOUNT_ID=your_test_account_id
FINAM_LIVE_REPORT_DATE_BEGIN=2026-01-01
FINAM_LIVE_REPORT_DATE_END=2026-01-02
FINAM_LIVE_ENABLE_GRPC=false

# Trading smoke checks are disabled unless this is explicitly set to 1.
# Payloads must be explicit JSON so the script never invents live order terms.
FINAM_LIVE_ENABLE_TRADING=0
FINAM_LIVE_PLACE_ORDER_JSON={"account_id":"your_test_account_id","symbol":"SBER@MISX","quantity":"1","side":"buy","type":"limit","limit_price":"1"}
FINAM_LIVE_SLTP_JSON={"account_id":"your_test_account_id","symbol":"SBER@MISX","side":"sell","quantity_sl":"1","sl_price":"1"}
